<!doctype html>
<html lang="en" class="">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
<link rel="stylesheet" href="/static/styles.css">
</head>
<body class="bg-paper text-charcoal font-body min-h-screen">
<header class="border-b border-sand">
  <div class="max-w-6xl mx-auto p-6">
    <h1 class="font-display text-2xl text-ink">{{.Title}}</h1>
  </div>
</header>
<main class="max-w-6xl mx-auto p-6 grid gap-4">
  <section>
    <div tabindex="0" class="capture-surface inline-block w-full">
      <img id="video" alt="Video stream" class="w-full bg-darkBg aspect-video">
    </div>
  </section>
  <aside class="grid gap-3">
    <div class="flex items-center gap-2">
      <label for="channel-selector" class="text-sm text-slate font-mono">channel</label>
      <select id="channel-selector" class="px-2 py-1 border border-sand bg-paper rounded text-sm font-mono text-charcoal">
{{range .Channels}}<option value="{{.ID}}">{{.Name}}</option>{{end}}
      </select>
    </div>
    <div id="control-sequences" class="flex flex-wrap gap-2"></div>
    <div><span id="status"></span></div>
  </aside>
</main>
<script type="module" src="/static/app.js"></script>
</body>
</html>
